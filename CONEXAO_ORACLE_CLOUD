import oracledb

def conectar_oracle():
    try:
        conexao = oracledb.connect(
            user="ADMIN",
            password="Aduser902060",
            dsn="ORCLAPI_HIGH"
        )

        print("Conexão realizada com sucesso no Oracle Cloud.")
        return conexao

    except oracledb.Error as erro:
        print("Erro ao conectar no banco Oracle:")
        print(erro)
        return None


def criar_tabela():
    conexao = conectar_oracle()

    if conexao is None:
        return

    cursor = conexao.cursor()

    sql_create_table = """
    CREATE TABLE CABOS_ELEITORAIS (
        ID NUMBER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
        NOME VARCHAR2(150) NOT NULL,
        EMAIL VARCHAR2(150),
        TELEFONE VARCHAR2(20),
        ENDERECO VARCHAR2(200)
    )
    """

    try:
        cursor.execute(sql_create_table)
        conexao.commit()
        print("Tabela CABOS_ELEITORAIS criada com sucesso.")
    except oracledb.Error as erro:
        print("Erro ao criar a tabela:")
        print(erro)
    finally:
        cursor.close()
        conexao.close()


if __name__ == "__main__":
    criar_tabela()